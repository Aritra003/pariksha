# Copy this file to .env.local and fill in your values
# NEVER commit .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# WalletConnect / RainbowKit
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Anthropic (for judge agent)
ANTHROPIC_API_KEY=

# NyayaMitra proxy (existing Railway backend)
NYAYAMITRA_VIDHI_PROXY_URL=
NYAYAMITRA_KOSH_PROXY_URL=
NYAYAMITRA_SAHAYAK_PROXY_URL=
NYAYAMITRA_RAKSHA_PROXY_URL=
NYAYAMITRA_PROXY_API_KEY=

# Smart contracts (set after Foundry deploy)
NEXT_PUBLIC_INFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_BADGE_CONTRACT_ADDRESS=
NEXT_PUBLIC_ATTESTATION_CONTRACT_ADDRESS=

# Chain configs
NEXT_PUBLIC_SEPOLIA_RPC=https://sepolia.drpc.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_ZEROG_GALILEO_RPC=
NEXT_PUBLIC_USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# KeeperHub
KEEPERHUB_API_KEY=

# Deploy private key (Foundry CLI only — NEVER in frontend code)
DEPLOYER_PRIVATE_KEY=
